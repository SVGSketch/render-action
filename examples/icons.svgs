{
  "schemaVersion": 1,
  "documentMetadata": {
    "title": "Icon Set",
    "description": "A grid of 10 icons built from first-class primitives (circle, rectangle, line, star, triangle, arrow, gear, ring, cross). Override the accent template variable to retheme the whole set.",
    "language": "en"
  },
  "templateVariables": [
    {
      "name": "accent",
      "type": "color",
      "defaultValue": "#3498db",
      "label": "Icon accent color",
      "description": "Primary stroke color for all icons."
    }
  ],
