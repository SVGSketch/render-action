{
  "schemaVersion": 1,
  "documentMetadata": {
    "title": "Monthly Active Users",
    "description": "A themed bar chart showing H1 growth. Override {{title}}, {{subtitle}}, {{barColorStart}} and {{barColorEnd}} at render time to produce a themed variant without touching the source.",
    "language": "en"
  },
  "templateVariables": [
    {
      "name": "title",
      "type": "string",
      "defaultValue": "Monthly Active Users",
      "label": "Chart title"
    },
    {
      "name": "subtitle",
      "type": "string",
      "defaultValue": "H1 2026  •  thousands",
      "label": "Chart subtitle"
    },
    {
      "name": "barColorStart",
      "type": "color",
      "defaultValue": "#3498db",
      "label": "Bar gradient — top color"
    },
    {
      "name": "barColorEnd",
      "type": "color",
      "defaultValue": "#1a5490",
      "label": "Bar gradient — bottom color"
    }
  ],
  "viewboxes": [
    {
      "id": "vb-1",
      "x": 0,
      "y": 0,
      "width": 720,
      "height": 460
    }
  ],
