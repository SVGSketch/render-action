{
  "schemaVersion": 1,
  "documentMetadata": {
    "title": "System Architecture",
    "description": "A three-tier system diagram showing client, API, and data layers connected by request arrows. Lives in git, re-rendered on every merge.",
    "language": "en"
  },
  "templateVariables": [
    {
      "name": "title",
      "type": "string",
      "defaultValue": "System Architecture",
      "label": "Diagram title"
    },
    {
      "name": "clientColor",
      "type": "color",
      "defaultValue": "#4299e1",
      "label": "Client tier color"
    },
    {
      "name": "apiColor",
      "type": "color",
      "defaultValue": "#38b2ac",
      "label": "API tier color"
    },
    {
      "name": "dataColor",
      "type": "color",
      "defaultValue": "#ed8936",
      "label": "Data tier color"
    }
  ],
  "viewboxes": [
    {
      "id": "vb-1",
      "x": 0,
      "y": 0,
      "width": 840,
      "height": 520
    }
  ],
  "shapes": [
    {
      "id": "bg",
      "type": "rectangle",
      "state": {
        "x": 0,
        "y": 0,
        "width": 840,
        "height": 520,
        "fillColor": "#f7fafc",
        "borderColor": "#f7fafc",
        "borderWidth": 0,
        "opacity": 1
      }
    },

    {
